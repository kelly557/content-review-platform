# Application
APP_NAME=AdReview
APP_ENV=dev
APP_DEBUG=true
APP_SECRET=change-me-in-production-please
APP_BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Database
DATABASE_URL=postgresql+asyncpg://adreview:adreview@localhost:5432/adreview
DATABASE_URL_SYNC=postgresql+psycopg2://adreview:adreview@localhost:5432/adreview

# Storage
STORAGE_ROOT=./storage
STORAGE_MAX_UPLOAD_MB=512
STORAGE_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/quicktime,application/pdf,text/plain

# JWT
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=120
JWT_REFRESH_TTL_DAY=14

# Logging
LOG_LEVEL=INFO
